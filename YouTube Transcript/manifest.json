{
  "manifest_version": 3,
  "name": "YouTube Transcript -> PDF",
  "version": "1.1.0",
  "description": "Extracts a YouTube video transcript, cleans it into readable paragraphs grouped by section, and downloads a formatted PDF.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://youtube.com/*",
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Transcript -> PDF",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://youtube.com/watch*",
        "https://*.youtube.com/watch*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/jspdf.umd.min.js"
      ],
      "matches": [
        "https://youtube.com/*",
        "https://*.youtube.com/*"
      ]
    }
  ]
}
